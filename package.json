{
  "name": "ceriale-web-components",
  "version": "0.1.3",
  "description": "A modern web component library built with Lit and TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run clean && tsc && vite build",
    "clean": "rm -rf dist",
    "pack": "npm run build && npm pack",
    "prepublishOnly": "npm run build",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "analyze": "cem analyze --litelement"
  },
  "keywords": [
    "web-components",
    "lit",
    "design-system",
    "typescript",
    "components"
  ],
  "author": "Pat Ceriale <pat.ceriale@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PatCeriale/ceriale-web-components.git"
  },
  "homepage": "https://github.com/PatCeriale/ceriale-web-components#readme",
  "bugs": {
    "url": "https://github.com/PatCeriale/ceriale-web-components/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.9.0",
    "@storybook/addon-essentials": "^7.6.17",
    "@storybook/addon-links": "^7.6.17",
    "@storybook/blocks": "^7.6.17",
    "@storybook/web-components": "^7.6.17",
    "@storybook/web-components-vite": "^7.6.17",
    "@types/jest": "^29.5.11",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "^7.6.17",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "lit": "^3.1.2"
  }
}
